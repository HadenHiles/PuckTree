# Environment Configuration
NODE_ENV=development

# Transaction Provider Service
PROVIDER_SERVICE_URL=http://localhost:8000

# Provider Configuration
# Options: pro_sports | fixture | disabled
TRANSACTION_PROVIDER=fixture

# Pro Sports Transactions Provider (only if TRANSACTION_PROVIDER=pro_sports)
# Unflare service URL for Cloudflare bypass
# See: https://github.com/iamyegor/Unflare
UNFLARE_SERVICE_URL=http://localhost:5002/scrape
UNFLARE_TIMEOUT_MS=60000

# Database (for hosted cache, not required for fixture mode)
# DATABASE_URL=postgresql://user:password@localhost:5432/pucktree

# IMPORTANT: Do not commit .env with real Unflare configuration or credentials
